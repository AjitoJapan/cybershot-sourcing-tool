{
  "title": "Cyber-shot eBay Market Updater",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "supabaseUrl": {
      "title": "Supabase URL",
      "type": "string",
      "description": "Example: https://xxxxxxxxxxxxxxxxxxxx.supabase.co",
      "prefill": "https://shejaburznracvhzzdhw.supabase.co",
      "editor": "textfield"
    },
    "supabaseServiceRoleKey": {
      "title": "Supabase service role key",
      "type": "string",
      "description": "Keep this private. Paste it only inside Apify.",
      "editor": "textfield",
      "isSecret": true
    },
    "models": {
      "title": "Models",
      "type": "array",
      "description": "Sony Cyber-shot T/TX models to update.",
      "editor": "stringList",
      "prefill": [
        "T1",
        "T2",
        "T5",
        "T7",
        "T9",
        "T10",
        "T11",
        "T20",
        "T30",
        "T33",
        "T50",
        "T70",
        "T77",
        "T90",
        "T100",
        "T200",
        "T300",
        "T500",
        "T700",
        "T900",
        "TX1",
        "TX5",
        "TX7",
        "TX9",
        "TX10",
        "TX20",
        "TX30",
        "TX55",
        "TX66",
        "TX100V",
        "TX200V",
        "TX300V"
      ]
    },
    "maxSoldItemsPerModel": {
      "title": "Sold items per model",
      "type": "integer",
      "description": "How many sold results to use for each model.",
      "default": 30,
      "minimum": 10,
      "maximum": 100,
      "editor": "number"
    },
    "delayMs": {
      "title": "Delay between models",
      "type": "integer",
      "description": "Small wait between eBay requests.",
      "default": 1500,
      "minimum": 500,
      "maximum": 10000,
      "editor": "number"
    },
    "useApifyProxy": {
      "title": "Use Apify Proxy",
      "type": "boolean",
      "description": "Turn this on if eBay returns 403 from the Apify server.",
      "default": true,
      "editor": "checkbox"
    },
    "proxyGroups": {
      "title": "Proxy groups",
      "type": "array",
      "description": "Leave empty for the default Apify Proxy. If eBay still blocks, try RESIDENTIAL if your Apify plan allows it.",
      "editor": "stringList",
      "prefill": []
    }
  },
  "required": ["supabaseUrl", "models"]
}
